@page
@model Planademic.Web.Pages.Schedule.IndexModel
@{
    ViewData["Title"] = "Study Schedule";
    ViewData["ActivePage"] = "Schedule";
}

@section TopbarActions {
    <div style="display:flex;gap:.5rem;">
        <button class="btn btn-ghost btn-sm">This week</button>
        <button class="btn btn-primary btn-sm">Regenerate</button>
    </div>
}

<div class="card" style="margin-bottom: 1.25rem;">
    <div class="card-header">
        <span class="card-title">Week of April 14 – 20</span>
    </div>
    <div class="card-body p0">

        <div class="week-row">
            <span class="week-day">Mon Apr 14</span>
            <div class="week-slots">
                <div class="week-slot-line">
                    <span class="ws-time">09:00 – 10:30</span>
                    <div class="slot-bar slot-indigo">Research essay draft</div>
                </div>
                <div class="week-slot-line">
                    <span class="ws-time">13:00 – 14:30</span>
                    <div class="slot-bar slot-indigo">Research essay draft</div>
                </div>
                <div class="week-slot-line">
                    <span class="ws-time">14:30 – 16:00</span>
                    <div class="slot-bar slot-teal">UML class diagram</div>
                </div>
            </div>
        </div>

        <div class="week-row">
            <span class="week-day">Tue Apr 15</span>
            <div class="week-slots">
                <div class="week-slot-line">
                    <span class="ws-time">10:00 – 11:30</span>
                    <div class="slot-bar slot-teal">UML class diagram</div>
                </div>
                <div class="week-slot-line">
                    <span class="ws-time">15:00 – 16:30</span>
                    <div class="slot-bar slot-amber">Weekly reflection</div>
                </div>
            </div>
        </div>

        <div class="week-row">
            <span class="week-day">Wed Apr 16</span>
            <div class="week-slots">
                <div class="week-slot-line">
                    <span class="ws-time">09:00 – 10:00</span>
                    <div class="slot-bar slot-amber">Database schema</div>
                </div>
                <div class="week-slot-line">
                    <span class="ws-time">13:00 – 15:00</span>
                    <div class="slot-bar slot-indigo">Research essay draft</div>
                </div>
            </div>
        </div>

        <div class="week-row">
            <span class="week-day">Thu Apr 17</span>
            <div class="week-slots">
                <div class="week-slot-line">
                    <span class="ws-time">11:00 – 12:00</span>
                    <div class="slot-bar slot-amber">Quiz preparation</div>
                </div>
            </div>
        </div>

        <div class="week-row week-row-last">
            <span class="week-day">Fri Apr 18</span>
            <div class="week-slots">
                <div class="week-slot-line">
                    <span class="ws-time">14:00 – 15:30</span>
                    <div class="slot-bar slot-teal">UML class diagram</div>
                </div>
            </div>
        </div>

    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">Workload heatmap</span>
    </div>
    <div class="card-body">
        <div class="heatmap-grid">
            <div class="hm-corner"></div>
            <div class="hm-daylabel">Mon</div>
            <div class="hm-daylabel">Tue</div>
            <div class="hm-daylabel">Wed</div>
            <div class="hm-daylabel">Thu</div>
            <div class="hm-daylabel">Fri</div>
            <div class="hm-daylabel">Sat</div>
            <div class="hm-daylabel">Sun</div>

            <div class="hm-rowlabel">Morning</div>
            <div class="hm-cell hm-4"></div>
            <div class="hm-cell hm-3"></div>
            <div class="hm-cell hm-3"></div>
            <div class="hm-cell hm-1"></div>
            <div class="hm-cell hm-0"></div>
            <div class="hm-cell hm-0"></div>
            <div class="hm-cell hm-0"></div>

            <div class="hm-rowlabel">Afternoon</div>
            <div class="hm-cell hm-3"></div>
            <div class="hm-cell hm-2"></div>
            <div class="hm-cell hm-4"></div>
            <div class="hm-cell hm-2"></div>
            <div class="hm-cell hm-1"></div>
            <div class="hm-cell hm-0"></div>
            <div class="hm-cell hm-0"></div>

            <div class="hm-rowlabel">Evening</div>
            <div class="hm-cell hm-1"></div>
            <div class="hm-cell hm-1"></div>
            <div class="hm-cell hm-0"></div>
            <div class="hm-cell hm-0"></div>
            <div class="hm-cell hm-0"></div>
            <div class="hm-cell hm-0"></div>
            <div class="hm-cell hm-0"></div>
        </div>

        <div class="heatmap-legend">
            <span>Low</span>
            <div class="hm-cell hm-0 hm-legend-cell"></div>
            <div class="hm-cell hm-1 hm-legend-cell"></div>
            <div class="hm-cell hm-2 hm-legend-cell"></div>
            <div class="hm-cell hm-3 hm-legend-cell"></div>
            <div class="hm-cell hm-4 hm-legend-cell"></div>
            <span>High</span>
        </div>
    </div>
</div>